# Database Configuration
# Using SQLite for local development (no server needed)
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=
DB_NAME=agric_stat
DATABASE_URL=sqlite:///./agric_stat.db

# FastAPI Backend Settings
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
DEBUG=True

# Frontend URLs
WEB_URL=http://localhost:3000
MOBILE_API_URL=http://192.168.1.100:8000

# Forecasting Settings
FORECAST_DAYS=30
FORECAST_MODEL=prophet

# Environment
ENVIRONMENT=development
